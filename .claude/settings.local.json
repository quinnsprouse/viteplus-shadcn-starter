{
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(vp dev*)",
      "Bash(vp check*)",
      "Bash(vp fmt*)",
      "Bash(vp lint*)",
      "Bash(vp test*)",
      "Bash(vp build*)",
      "Bash(vp add*)",
      "Bash(vp remove*)",
      "Bash(vp install*)",
      "Bash(vp dlx*)",
      "Bash(npm run check*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run knip*)",
      "Bash(npm install*)",
      "Bash(npx tsc*)",
      "Bash(npx shadcn*)",
      "Bash(npx commitlint*)",
      "Bash(npx playwright*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(curl*)",
      "Bash(node -v*)",
      "Bash(node -e*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(mkdir*)",
      "Bash(chmod*)",
      "Bash(which*)",
      "Bash(lsof*)",
      "Bash(wc*)",
      "Bash(find*)",
      "Bash(source*)",
      "WebFetch(domain:viteplus.dev)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nitro.build)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:github.com)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(npm publish*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.npmrc)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "vp fmt \"$CLAUDE_FILE_PATH\" 2>/dev/null; npx tsc -b --noEmit 2>&1 | head -20 || true"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "vp fmt \"$CLAUDE_FILE_PATH\" 2>/dev/null; npx tsc -b --noEmit 2>&1 | head -20 || true"
          }
        ]
      }
    ]
  }
}
